{
  "version": 1,
  "product": "Scafforge",
  "output_profiles": ["opencode"],
  "optional_extensions": [],
  "run_types": {
    "greenfield": {
      "entrypoint": "scaffold-kickoff",
      "sequence": [
        "spec-pack-normalizer",
        "repo-scaffold-factory",
        "opencode-team-bootstrap",
        "ticket-pack-builder:bootstrap",
        "project-skill-bootstrap:foundation",
        "project-skill-bootstrap:synthesis_if_evidence",
        "agent-prompt-engineering",
        "scafforge-audit:audit_then_route_repair_if_needed",
        "handoff-brief"
      ]
    },
    "retrofit": {
      "entrypoint": "scaffold-kickoff",
      "sequence": [
        "spec-pack-normalizer:if_needed",
        "opencode-team-bootstrap",
        "ticket-pack-builder:refine_if_needed",
        "project-skill-bootstrap:foundation_or_repair",
        "scafforge-audit:audit_then_route_repair_if_needed",
        "handoff-brief"
      ]
    },
    "managed-repair": {
      "entrypoint": "scaffold-kickoff",
      "sequence": [
        "scafforge-repair:apply-safe-repair",
        "opencode-team-bootstrap:follow_up_if_project_specific_drift",
        "ticket-pack-builder:refine_if_needed",
        "project-skill-bootstrap:repair_if_needed",
        "handoff-brief"
      ]
    },
    "diagnosis-review": {
      "entrypoint": "scaffold-kickoff",
      "sequence": [
        "scafforge-audit:review_and_emit_diagnosis_pack",
        "handoff-brief"
      ]
    }
  },
  "skills": {
    "scaffold-kickoff": {
      "owner": "conductor",
      "modes": ["greenfield", "retrofit", "managed-repair", "diagnosis-review"],
      "inputs": ["messy project inputs", "normalized decisions"],
      "outputs": ["orchestrated run", "required downstream sequence"],
      "upstreams": [],
      "downstreams": ["spec-pack-normalizer", "repo-scaffold-factory", "opencode-team-bootstrap", "ticket-pack-builder", "project-skill-bootstrap", "agent-prompt-engineering", "scafforge-audit", "scafforge-repair", "handoff-brief"]
    },
    "spec-pack-normalizer": {
      "owner": "intake",
      "modes": ["normalize"],
      "inputs": ["docs", "notes", "spec packs", "fragmented plans"],
      "outputs": ["canonical brief", "decision packet", "backlog readiness"],
      "upstreams": ["scaffold-kickoff"],
      "downstreams": ["repo-scaffold-factory", "ticket-pack-builder"]
    },
    "repo-scaffold-factory": {
      "owner": "scaffold",
      "modes": ["full", "opencode"],
      "inputs": ["canonical brief", "provider/model choices", "project identifiers"],
      "outputs": ["repo skeleton", "template docs", ".opencode layer", "bootstrap provenance"],
      "upstreams": ["spec-pack-normalizer", "scaffold-kickoff"],
      "downstreams": ["opencode-team-bootstrap", "ticket-pack-builder", "project-skill-bootstrap", "scafforge-audit"]
    },
    "opencode-team-bootstrap": {
      "owner": "agent-team-design",
      "modes": ["design", "retrofit"],
      "inputs": ["canonical brief", "base scaffold agents", "project type"],
      "outputs": ["project-specific agents", "customized tools/plugins", "team structure"],
      "upstreams": ["repo-scaffold-factory", "scaffold-kickoff"],
      "downstreams": ["ticket-pack-builder", "project-skill-bootstrap", "scafforge-audit", "scafforge-repair"]
    },
    "ticket-pack-builder": {
      "owner": "queue",
      "modes": ["bootstrap", "refine", "remediation-follow-up"],
      "inputs": ["canonical brief", "decision packet", "backlog readiness", "audit/repair ticket recommendations"],
      "outputs": ["tickets", "manifest", "board", "decision/blocker tickets", "remediation/verification tickets"],
      "upstreams": ["spec-pack-normalizer", "repo-scaffold-factory", "opencode-team-bootstrap", "scafforge-audit", "scafforge-repair"],
      "downstreams": ["project-skill-bootstrap", "handoff-brief"]
    },
    "project-skill-bootstrap": {
      "owner": "local-skills",
      "modes": ["foundation", "synthesis"],
      "inputs": ["repo structure", "stack evidence", "workflow contract"],
      "outputs": ["foundation skill pack", "synthesized local skills"],
      "upstreams": ["repo-scaffold-factory", "opencode-team-bootstrap", "ticket-pack-builder"],
      "downstreams": ["agent-prompt-engineering", "scafforge-audit"]
    },
    "agent-prompt-engineering": {
      "owner": "prompts",
      "modes": ["required-pass"],
      "inputs": ["workflow contract", "weak-model constraints", "repo context"],
      "outputs": ["hardened prompts", "blocker rules", "anti-summary rails"],
      "upstreams": ["project-skill-bootstrap", "repo-scaffold-factory"],
      "downstreams": ["scafforge-audit"]
    },
    "scafforge-audit": {
      "owner": "audit-review",
      "modes": ["audit", "review", "diagnosis-pack"],
      "inputs": ["repo workflow surfaces", "contract docs", "template outputs", "optional PR/review evidence"],
      "outputs": ["diagnosis", "validated review findings", "four-report pack", "ticket recommendations"],
      "upstreams": ["repo-scaffold-factory", "opencode-team-bootstrap", "agent-prompt-engineering", "project-skill-bootstrap", "scaffold-kickoff"],
      "downstreams": ["scafforge-repair", "ticket-pack-builder", "handoff-brief"]
    },
    "scafforge-repair": {
      "owner": "managed-repair",
      "modes": ["apply-safe-repair"],
      "inputs": ["audit outputs", "repair plan", "validated workflow drift"],
      "outputs": ["safe repairs", "provenance updates", "verification results", "ticket follow-up routing"],
      "upstreams": ["scafforge-audit", "scaffold-kickoff", "opencode-team-bootstrap"],
      "downstreams": ["ticket-pack-builder", "handoff-brief"]
    },
    "handoff-brief": {
      "owner": "restart-surface",
      "modes": ["publish"],
      "inputs": ["tickets", "workflow state", "artifacts", "diagnosis"],
      "outputs": ["START-HERE refresh", "closeout summary", "restart surface"],
      "upstreams": ["scafforge-audit", "scafforge-repair", "ticket-pack-builder"],
      "downstreams": []
    }
  }
}
