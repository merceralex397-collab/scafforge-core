{
  "version": 1,
  "product": "Scafforge",
  "output_profiles": ["opencode"],
  "run_types": {
    "greenfield": {
      "entrypoint": "scaffold-kickoff",
      "sequence": [
        "spec-pack-normalizer",
        "repo-scaffold-factory",
        "ticket-pack-builder:bootstrap",
        "project-skill-bootstrap:foundation",
        "project-skill-bootstrap:synthesis_if_evidence",
        "agent-prompt-engineering:conditional",
        "repo-process-doctor:audit_or_apply_safe_repair",
        "handoff-brief"
      ]
    },
    "retrofit": {
      "entrypoint": "scaffold-kickoff",
      "sequence": [
        "spec-pack-normalizer:if_needed",
        "opencode-team-bootstrap",
        "ticket-pack-builder:refine_if_needed",
        "project-skill-bootstrap:foundation_or_repair",
        "repo-process-doctor:audit_or_apply_safe_repair",
        "handoff-brief"
      ]
    }
  },
  "skills": {
    "scaffold-kickoff": {
      "owner": "conductor",
      "modes": ["greenfield", "retrofit"],
      "inputs": ["messy project inputs", "normalized decisions"],
      "outputs": ["orchestrated run", "required downstream sequence"],
      "upstreams": [],
      "downstreams": ["spec-pack-normalizer", "repo-scaffold-factory", "ticket-pack-builder", "project-skill-bootstrap", "agent-prompt-engineering", "repo-process-doctor", "handoff-brief"]
    },
    "spec-pack-normalizer": {
      "owner": "intake",
      "modes": ["normalize"],
      "inputs": ["docs", "notes", "spec packs", "fragmented plans"],
      "outputs": ["canonical brief", "decision packet", "backlog readiness"],
      "upstreams": ["scaffold-kickoff"],
      "downstreams": ["repo-scaffold-factory", "ticket-pack-builder"]
    },
    "repo-scaffold-factory": {
      "owner": "scaffold",
      "modes": ["full", "opencode"],
      "inputs": ["canonical brief", "provider/model choices", "project identifiers"],
      "outputs": ["repo skeleton", "template docs", ".opencode layer", "bootstrap provenance"],
      "upstreams": ["spec-pack-normalizer", "scaffold-kickoff"],
      "downstreams": ["ticket-pack-builder", "project-skill-bootstrap", "repo-process-doctor"]
    },
    "opencode-team-bootstrap": {
      "owner": "retrofit",
      "modes": ["opencode-only"],
      "inputs": ["existing repo", "provider/model choices", "project identifiers"],
      "outputs": ["project-local OpenCode layer", "bootstrap provenance"],
      "upstreams": ["scaffold-kickoff"],
      "downstreams": ["project-skill-bootstrap", "repo-process-doctor"]
    },
    "ticket-pack-builder": {
      "owner": "queue",
      "modes": ["bootstrap", "refine"],
      "inputs": ["canonical brief", "decision packet", "backlog readiness"],
      "outputs": ["tickets", "manifest", "board", "decision/blocker tickets"],
      "upstreams": ["spec-pack-normalizer", "repo-scaffold-factory", "opencode-team-bootstrap"],
      "downstreams": ["project-skill-bootstrap", "handoff-brief"]
    },
    "project-skill-bootstrap": {
      "owner": "local-skills",
      "modes": ["foundation", "synthesis"],
      "inputs": ["repo structure", "stack evidence", "workflow contract"],
      "outputs": ["foundation skill pack", "synthesized local skills"],
      "upstreams": ["repo-scaffold-factory", "opencode-team-bootstrap", "ticket-pack-builder"],
      "downstreams": ["agent-prompt-engineering", "repo-process-doctor"]
    },
    "agent-prompt-engineering": {
      "owner": "prompts",
      "modes": ["conditional"],
      "inputs": ["workflow contract", "weak-model constraints", "repo context"],
      "outputs": ["hardened prompts", "blocker rules", "anti-summary rails"],
      "upstreams": ["project-skill-bootstrap", "repo-scaffold-factory"],
      "downstreams": ["repo-process-doctor"]
    },
    "repo-process-doctor": {
      "owner": "audit-repair",
      "modes": ["audit", "propose-repair", "apply-repair"],
      "inputs": ["repo workflow surfaces", "contract docs", "template outputs"],
      "outputs": ["diagnosis", "repair plan", "safe repairs", "reports"],
      "upstreams": ["repo-scaffold-factory", "opencode-team-bootstrap", "agent-prompt-engineering", "project-skill-bootstrap"],
      "downstreams": ["handoff-brief"]
    },
    "review-audit-bridge": {
      "owner": "qa",
      "modes": ["implementation-review"],
      "inputs": ["approved plans", "implementation artifacts", "review artifacts"],
      "outputs": ["review sequence", "security review", "qa findings"],
      "upstreams": [],
      "downstreams": []
    },
    "handoff-brief": {
      "owner": "restart-surface",
      "modes": ["publish"],
      "inputs": ["tickets", "workflow state", "artifacts", "diagnosis"],
      "outputs": ["START-HERE refresh", "closeout summary", "restart surface"],
      "upstreams": ["repo-process-doctor", "ticket-pack-builder"],
      "downstreams": []
    }
  }
}
