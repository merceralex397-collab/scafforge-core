{
  "version": 1,
  "product": "Scafforge",
  "output_profiles": ["opencode"],
  "optional_extensions": ["asset-pipeline"],
  "flow_graph_sanity": {
    "single_public_entrypoint": "scaffold-kickoff",
    "all_run_types_end_with": "handoff-brief",
    "validate_sequence_modes": true,
    "acyclic_except_contract_smells": ["CYCLE001"]
  },
  "skill_governance": {
    "intake": {
      "accepted_package_evidence": [
        "package-evidence-bundle.json",
        "active-audits/<repo>/evidence-manifest.json",
        "active-audits/<repo>/investigator/report.json"
      ],
      "classification_lanes": [
        "prompt-contract-gap",
        "workflow-boundary-gap",
        "missing-capability-gap",
        "non-skill-package-work"
      ],
      "staging_locations": [
        "active-audits/<repo>/ for audit-accepted package evidence",
        "active-plans/<plan>/references/ for non-audit candidates until they become bounded package work"
      ]
    },
    "external_sources": {
      "rubric_reference": "references/external-source-evaluation-rubric.md",
      "rejected_sources_reference": "references/rejected-sources.md",
      "direct_import_policy": "forbidden",
      "distillation_requirement": "scafforge-owned-language"
    },
    "catalog_limits": {
      "max_package_skills": 12,
      "max_default_local_skills": 12
    },
    "validation_surface": {
      "entrypoint": "npm run validate:contract",
      "script": "scripts/validate_scafforge_contract.py",
      "manual_review_required": [
        "distillation_quality",
        "originality_vs_source_overlap",
        "weak_model_navigability"
      ]
    }
  },
  "contract_smells": [
    {
      "code": "CYCLE001",
      "title": "Project-skill and team-bootstrap dependency seam",
      "status": "accepted-temporary-debt",
      "skills": ["project-skill-bootstrap", "opencode-team-bootstrap"],
      "current_order": [
        "project-skill-bootstrap:full-greenfield-pass",
        "opencode-team-bootstrap"
      ],
      "why_safe_now": "Greenfield keeps project-skill-bootstrap before opencode-team-bootstrap so generated agent allowlists can reference repo-local skills that already exist.",
      "removal_condition": "Replace this seam only after Scafforge splits minimal-operable managed surfaces from later project-specific specialization."
    }
  ],
  "run_types": {
    "greenfield": {
      "entrypoint": "scaffold-kickoff",
      "sequence": [
        "spec-pack-normalizer",
        "repo-scaffold-factory",
        "repo-scaffold-factory:verify-bootstrap-lane",
        "project-skill-bootstrap:full-greenfield-pass",
        "opencode-team-bootstrap",
        "agent-prompt-engineering",
        "ticket-pack-builder:bootstrap",
        "repo-scaffold-factory:verify-generated-scaffold",
        "handoff-brief"
      ]
    },
    "greenfield-game": {
      "entrypoint": "scaffold-kickoff",
      "sequence": [
        "spec-pack-normalizer",
        "repo-scaffold-factory",
        "repo-scaffold-factory:verify-bootstrap-lane",
        "project-skill-bootstrap:full-greenfield-pass",
        "asset-pipeline:configure",
        "opencode-team-bootstrap",
        "agent-prompt-engineering",
        "ticket-pack-builder:bootstrap",
        "repo-scaffold-factory:verify-generated-scaffold",
        "handoff-brief"
      ]
    },
    "retrofit": {
      "entrypoint": "scaffold-kickoff",
      "sequence": [
        "spec-pack-normalizer:if_needed",
        "opencode-team-bootstrap",
        "project-skill-bootstrap:repair-or-regeneration",
        "ticket-pack-builder:refine_if_needed",
        "scafforge-audit:audit_then_route_repair_if_needed",
        "handoff-brief"
      ]
    },
    "managed-repair": {
      "entrypoint": "scaffold-kickoff",
      "sequence": [
        "scafforge-repair:apply-safe-repair",
        "project-skill-bootstrap:repair-or-regeneration_if_needed",
        "opencode-team-bootstrap:follow_up_if_project_specific_drift",
        "agent-prompt-engineering:repair-hardening_if_needed",
        "ticket-pack-builder:refine_if_needed",
        "handoff-brief"
      ]
    },
    "pivot": {
      "entrypoint": "scaffold-kickoff",
      "sequence": [
        "scafforge-pivot:classify_and_route",
        "project-skill-bootstrap:repair-or-regeneration_if_needed",
        "opencode-team-bootstrap:follow_up_if_project_specific_drift",
        "agent-prompt-engineering:repair-hardening_if_needed",
        "ticket-pack-builder:refine_if_needed",
        "scafforge-repair:follow_up_if_managed_workflow_drift",
        "handoff-brief"
      ]
    },
    "diagnosis-review": {
      "entrypoint": "scaffold-kickoff",
      "sequence": [
        "scafforge-audit:review_and_emit_diagnosis_pack",
        "handoff-brief"
      ]
    }
  },
  "skills": {
    "scaffold-kickoff": {
      "owner": "conductor",
      "modes": ["greenfield", "retrofit", "managed-repair", "pivot", "diagnosis-review"],
      "inputs": ["messy project inputs", "normalized decisions"],
      "outputs": ["orchestrated run", "required downstream sequence"],
      "required_outputs": [
        "canonical brief or diagnosis scope",
        "authority baseline from references/authority-adr.md and references/invariant-catalog.md",
        "selected run-type completion state",
        "aligned ticket/workflow restart surface",
        "same-session immediate continuation verification gate"
      ],
      "upstreams": [],
      "downstreams": ["spec-pack-normalizer", "repo-scaffold-factory", "project-skill-bootstrap", "opencode-team-bootstrap", "agent-prompt-engineering", "ticket-pack-builder", "scafforge-audit", "scafforge-repair", "scafforge-pivot", "handoff-brief"]
    },
    "spec-pack-normalizer": {
      "owner": "intake",
      "modes": ["normalize", "if_needed"],
      "inputs": ["docs", "notes", "spec packs", "fragmented plans"],
      "outputs": ["canonical brief", "decision packet", "backlog readiness"],
      "required_outputs": [
        "docs/spec/CANONICAL-BRIEF.md",
        "batched blocking-decision packet",
        "backlog readiness signal"
      ],
      "upstreams": ["scaffold-kickoff"],
      "downstreams": ["repo-scaffold-factory"]
    },
    "repo-scaffold-factory": {
      "owner": "scaffold",
      "modes": ["full", "opencode", "verify-bootstrap-lane", "verify-generated-scaffold"],
      "inputs": ["canonical brief", "provider/model choices", "project identifiers"],
      "outputs": ["repo skeleton", "template docs", ".opencode layer", "bootstrap provenance"],
      "upstreams": ["spec-pack-normalizer", "scaffold-kickoff"],
      "downstreams": ["project-skill-bootstrap", "scafforge-audit"]
    },
    "opencode-team-bootstrap": {
      "owner": "agent-team-design",
      "modes": ["design", "retrofit", "follow_up_if_project_specific_drift"],
      "inputs": ["canonical brief", "base scaffold agents or existing repo", "repo-local skill pack when present", "project type"],
      "outputs": ["project-specific agents", "customized tools/plugins", "team structure"],
      "required_outputs": [
        "project-specific .opencode/agents/",
        "agent/skill allowlist consistency",
        "lease-ownership and delegation consistency"
      ],
      "upstreams": ["project-skill-bootstrap", "spec-pack-normalizer", "scaffold-kickoff", "scafforge-repair"],
      "downstreams": ["project-skill-bootstrap", "agent-prompt-engineering", "ticket-pack-builder", "scafforge-audit"]
    },
    "ticket-pack-builder": {
      "owner": "queue",
      "modes": ["bootstrap", "refine", "refine_if_needed", "remediation-follow-up"],
      "inputs": ["canonical brief", "decision packet", "backlog readiness", "finalized local workflow surfaces", "audit/repair ticket recommendations"],
      "outputs": ["tickets", "manifest", "board", "decision/blocker tickets", "remediation/verification tickets"],
      "required_outputs": [
        "tickets/manifest.json",
        "tickets/BOARD.md",
        "tickets/<id>.md files",
        ".opencode/state/workflow-state.json aligned to active ticket"
      ],
      "upstreams": ["agent-prompt-engineering", "opencode-team-bootstrap", "scafforge-audit", "scafforge-repair"],
      "downstreams": ["handoff-brief"]
    },
    "project-skill-bootstrap": {
      "owner": "local-skills",
      "modes": ["full-greenfield-pass", "repair-or-regeneration", "repair-or-regeneration_if_needed"],
      "inputs": ["repo structure", "stack evidence", "workflow contract", "selected downstream model profile"],
      "outputs": ["repo-local skill pack", "synthesized local skills", "model operating profile"],
      "required_outputs": [
        "baseline .opencode/skills pack populated",
        ".opencode/skills/model-operating-profile/SKILL.md",
        "no scaffold placeholder text in generated local skills"
      ],
      "upstreams": ["repo-scaffold-factory", "opencode-team-bootstrap", "scaffold-kickoff", "scafforge-repair"],
      "downstreams": ["opencode-team-bootstrap", "agent-prompt-engineering", "scafforge-audit"]
    },
    "agent-prompt-engineering": {
      "owner": "contract-alignment",
      "modes": ["required-pass", "repair-hardening_if_needed"],
      "inputs": ["workflow contract", "weak-model constraints", "repo context"],
      "outputs": ["hardened prompts", "blocker rules", "anti-summary rails"],
      "required_outputs": [
        "team-leader prompt aligned to transition guidance",
        "specialist prompts aligned to lease and artifact ownership",
        "slash-command human-entrypoint boundary"
      ],
      "upstreams": ["project-skill-bootstrap", "opencode-team-bootstrap", "repo-scaffold-factory"],
      "downstreams": ["ticket-pack-builder", "scafforge-audit"]
    },
    "scafforge-audit": {
      "owner": "diagnosis-disposition",
      "modes": ["full-diagnosis", "audit_then_route_repair_if_needed", "review_and_emit_diagnosis_pack"],
      "inputs": ["repo workflow surfaces", "contract docs", "template outputs", "optional PR/review evidence"],
      "outputs": ["diagnosis", "validated review findings", "four-report pack", "ticket recommendations", "package evidence bundle"],
      "required_outputs": [
        "authoritative disposition bundle",
        "evidence-backed finding ownership",
        "code-quality findings for execution and reference-integrity failures",
        "package evidence bundle and escalation decision when package work is implicated"
      ],
      "upstreams": ["repo-scaffold-factory", "opencode-team-bootstrap", "agent-prompt-engineering", "project-skill-bootstrap", "scaffold-kickoff"],
      "downstreams": ["scafforge-repair", "ticket-pack-builder", "handoff-brief"]
    },
    "scafforge-repair": {
      "owner": "runtime-mutation",
      "modes": ["apply-safe-repair", "follow_up_if_managed_workflow_drift"],
      "inputs": ["audit outputs", "repair plan", "validated workflow drift"],
      "outputs": ["safe repairs", "project-specific regeneration", "prompt-hardening refresh", "provenance updates", "verification results", "ticket follow-up routing"],
      "required_outputs": [
        "repair_follow_on outcome derived from the authoritative disposition bundle",
        "verified final snapshot before restart publication",
        "non-destructive provenance for any managed-surface replacement",
        "truthful restart publication that still waits on fresh post-package revalidation when package work had to land first"
      ],
      "upstreams": ["scafforge-audit", "scaffold-kickoff", "opencode-team-bootstrap"],
      "downstreams": ["ticket-pack-builder", "handoff-brief"]
    },
    "scafforge-pivot": {
      "owner": "pivot-state",
      "modes": ["classify-and-route", "classify_and_route"],
      "inputs": ["requested change", "canonical brief", "current ticket graph", "workflow state", "existing repo surfaces"],
      "outputs": ["pivot classification", "brief update", "stale-surface map", "bounded refresh routing", "verification result"],
      "required_outputs": [
        "pivot classification",
        "docs/spec/CANONICAL-BRIEF.md updated with pivot history",
        "machine-readable stale-surface map",
        ".opencode/meta/pivot-state.json",
        "explicit downstream refresh routing"
      ],
      "upstreams": ["scaffold-kickoff"],
      "downstreams": ["project-skill-bootstrap", "opencode-team-bootstrap", "agent-prompt-engineering", "ticket-pack-builder", "scafforge-repair", "handoff-brief"]
    },
    "asset-pipeline": {
      "owner": "asset-orchestration",
      "modes": ["configure", "configure_if_needed"],
      "inputs": ["canonical brief", "project type", "art style", "platform constraints"],
      "outputs": ["requirements.json", "pipeline.json", "manifest.json", "asset QA surfaces", "PROVENANCE.md", "asset briefs", "blender-mcp subagent config"],
      "required_outputs": [
        "assets/requirements.json",
        "assets/pipeline.json",
        "assets/manifest.json",
        "assets/qa/import-report.json",
        "assets/qa/license-report.json",
        "assets/PROVENANCE.md",
        ".opencode/meta/asset-provenance-lock.json"
      ],
      "upstreams": ["repo-scaffold-factory", "project-skill-bootstrap"],
      "downstreams": ["ticket-pack-builder", "handoff-brief"]
    },
    "handoff-brief": {
      "owner": "restart-publication",
      "modes": ["publish"],
      "inputs": ["tickets", "workflow state", "artifacts", "diagnosis"],
      "outputs": ["START-HERE refresh", "closeout summary", "restart surface"],
      "required_outputs": [
        "START-HERE.md",
        ".opencode/state/latest-handoff.md",
        "read order with manifest before board",
        "next action bounded by current evidence",
        "restart surfaces published only from the verified final snapshot"
      ],
      "upstreams": ["scafforge-audit", "scafforge-repair", "ticket-pack-builder"],
      "downstreams": []
    }
  }
}
